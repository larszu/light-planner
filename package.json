{
  "name": "light-planner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "shots": "node scripts/render-shots.mjs",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win",
    "dist:win": "npm run build && electron-builder --win nsis portable --publish never",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64 --publish never"
  },
  "dependencies": {
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.0"
  },
  "build": {
    "appId": "com.larszumpe.lightplanner",
    "productName": "Light Planner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "portable": {
      "artifactName": "Light-Planner-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "x64"
        },
        {
          "target": "dmg",
          "arch": "arm64"
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.graphics-design",
      "artifactName": "Light-Planner-${version}-${arch}.${ext}",
      "identity": "-",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Light-Planner-Setup-${version}.${ext}"
    }
  }
}
