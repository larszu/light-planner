{
  "name": "light-planner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win",
    "dist:win": "npm run build && electron-builder --win nsis portable --publish never",
    "dist:mac": "npm run build && electron-builder --mac zip --x64 --arm64 --publish never"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.larszumpe.lightplanner",
    "productName": "Light Planner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.graphics-design",
      "identity": null
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
